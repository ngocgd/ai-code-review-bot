# Database
DATABASE_URL="postgresql://reviewer:reviewer123@localhost:5432/code_review"

# Redis
REDIS_URL="redis://localhost:6379"

# GitHub App
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ============================================================
# LLM Provider: claude | gemini | ollama
# Primary provider tried first, others are fallback
# ============================================================
LLM_PROVIDER=ollama

# Claude (best quality — dùng OAuth token từ Claude Code CLI)
ANTHROPIC_API_KEY=

# Gemini (free tier — 15 req/min)
GEMINI_API_KEY=

# Ollama (local, free, unlimited — default for development)
OLLAMA_BASE_URL=http://localhost:11434

# App
PORT=3000
NODE_ENV=development
